{
  "name": "bashrc-setup",
  "version": "1.0.0",
  "type": "module",
  "private": "true",
  "config": {
    "dependencies_pre-scripts": "bash-first-and-only-one-time.sh,bash-profile-barebone.sh,bootstrap/dependencies-mac.sh,bootstrap/dependencies-ubuntu.sh,bootstrap/dependencies-windows.sh,bootstrap/dependencies-chrome-os-linux.sh,bootstrap/dependencies-android-termux.sh,bootstrap/dependencies-arch-linux-steam-deck.sh"
  },
  "scripts": {
    "dev": "vite",
    "prebuild": "npm run format",
    "build": "vite build",
    "preview": "vite preview",
    "start": "npx http-server --cors .",
    "preformat": "node software/types/generate-types.cjs",
    "format": "prettier --write --print-width 140 --ignore-unknown --no-error-on-unmatched-pattern --cache '**/*.{js,jsx,ts,tsx,mjs,cjs,json,jsonc,html,css,scss,less,md,yml,yaml,graphql,vue,xml}'",
    "clean": "rm -rf dist",
    "setup:full": "curl -s https://raw.githubusercontent.com/synle/bashrc/master/run.sh | bash -s -- --prod --pre-scripts=\"bash-first-and-only-one-time.sh,bash-profile-barebone.sh\"",
    "setup:light": "curl -s https://raw.githubusercontent.com/synle/bashrc/master/run.sh | bash -s -- --prod --files=\"_bash-rc-bootstrap.js,git.js,vim-configurations.js,vim-vundle.sh,bash-inputrc.js,bash-autocomplete.js,bash-syle-content.js\"",
    "setup:hosts": "curl -s https://raw.githubusercontent.com/synle/bashrc/master/run.sh | bash -s -- --prod --files=\"software/scripts/etc-hosts.su.js\"",
    "setup:dependencies": "curl -s https://raw.githubusercontent.com/synle/bashrc/master/run.sh | bash -s -- --prod --run-only-prescripts --pre-scripts=\"$npm_package_config_dependencies_pre-scripts\"",
    "test": "sh run.sh",
    "test:dependencies": "sh run.sh --run-only-prescripts --pre-scripts=\"$npm_package_config_dependencies_pre-scripts\"",
    "test:hosts": "sh run.sh --files=\"software/scripts/etc-hosts.su.js\"",
    "list:scripts": "cat software/metadata/script-list.config"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "toastify-js": "^1.12.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "prettier": "^3.8.1",
    "sass": "^1.97.3",
    "vite": "^4.4.0",
    "vite-plugin-singlefile": "^0.13.5"
  }
}
