{
  "name": "bashrc-setup",
  "version": "1.0.0",
  "scripts": {
    "dev": "vite",
    "prebuild": "npm run format",
    "build": "vite build",
    "format": "npx --yes prettier --write --cache --ignore-unknown --no-error-on-unmatched-pattern --print-width 140 .",
    "setup:hosts": "curl -s https://raw.githubusercontent.com/synle/bashrc/master/run.sh | bash -s -- --files=\"software/scripts/etc-hosts.su.js\"",
    "test": "vitest run --config vitest.config.js",
    "test:smoke": "vitest run --config vitest.smoke.config.js",
    "test:smoke:local": "vitest run --config vitest.smoke.local.config.js",
    "test:profile": "vitest run --config vitest.profile.config.js",
    "test:buildconfig": "vitest run --config vitest.buildconfig.config.js",
    "test:buildconfig:update": "vitest run --config vitest.buildconfig.config.js --update"
  },
  "dependencies": {
    "prismjs": "^1.29.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "prettier": "^3.8.1",
    "puppeteer": "^24.40.0",
    "sass": "^1.99.0",
    "typescript": "^5.9.3",
    "vite": "^4.4.0",
    "vite-plugin-singlefile": "^0.13.5",
    "vitest": "^0.34.6"
  }
}
