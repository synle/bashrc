## fzf alias for synle-make-component
getMakeComponentOptions(){
  make-help
}

fuzzyMakeComponent(){
  makeComponentCommand=$((         getMakeComponentOptions         ) | sed '/^s*$/d' | uniq | fzf)
  echo "$makeComponentCommand"
  $makeComponentCommand
}
