# Include version based config for easier debugging
# Do NOT use this include if you want to persist custom changes, use ~/.ssh/config.custom instead
Include ~/.ssh/config.v2.0.20

# Include any user specified SSH configuration
Include ~/.ssh/config.custom

# Include rdev configuration file.See https://go/remote-development
Include ~/.ssh/config.rdev

# Include EPE managed configs for accessing some of the BIZ servers
Include ~/.ssh/config.epe

# This is disabled by default. We enable it so that once a key is unlocked it
#   will be added to the user's SSH agent so future SSH auth is password-less
AddKeysToAgent yes

# https://developer.apple.com/library/archive/technotes/tn2449/_index.html
# TL;DR This is a macOS specific directive, causes macOS to prompt for the SSH
#   key passphrase in the UI and store it in the system keychain for later use
UseKeychain yes

# Disable default set of keys (id_rsa, id_dsa, etc.). If you need them for an
#   external site (ex. github.com), this can be added through the ~/.ssh/config.custom
IdentityFile none

# Setup default order of preferred authentication methods to prefer "publickey" which is used for
# certificate based auth. gss API is used on grid for Kerberos based auth and keyboard-interactive
# and password are used on BIZ hosts and for old style 2fa (with yubikey on the password prompt).
# Compared to default value, this removes the "hostbased" method which is not used at LinkedIn.
PreferredAuthentications publickey,gssapi-with-mic,keyboard-interactive,password

