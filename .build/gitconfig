[alias]
# ---- Status & Staging ----
s = "!git status -sb && git diff --stat" # Status + diff summary
stat = status -sb # Short status with branch info
a = add
aa = add -A # Add all (including untracked)
ap = add -p # Interactive patch mode
au = add -u # Add only tracked files

# ---- Commit ----
c  = commit --allow-empty --no-verify
cm = commit --allow-empty --no-verify -m
amend  = commit --allow-empty --no-verify --amend
amendm = commit --allow-empty --no-verify --amend -m
wip = "!git aa && git cm wip" # Quick save-all as a wip commit
unwip = "!git log -1 --format=%s | grep -qi '^wip$' && git undo" # Undo last commit only if it was a wip

# ---- Undo ----
undo = reset HEAD~1 --mixed # Undo last commit, keep changes unstaged

# ---- Patch ----
patch = apply --reject --whitespace=fix # Apply a .patch file
patch-getn = "!f() { git format-patch -${1:-1}; }; f" # Save last N commits as .patch files
patch-get = "!git patch-getn 1" # Save last commit as .patch file
patch-viewn = "!f() { git format-patch -${1:-1} --stdout; }; f" # Print last N commits patch to stdout
patch-view = "!git patch-viewn 1" # Print last commit patch to stdout
patch-downloadn = "!f() { git patch-getn ${1:-1} && git patch-rename; }; f" # patch-get + rename with repo-date prefix
patch-download = "!git patch-downloadn 1" # Download last commit patch with repo-date prefix
patch-rename = "!f() { r=$(basename $(git rev-parse --show-toplevel)); d=$(date +%Y_%m_%d_%H_%M); for p in *.patch; do [ -f \"$p\" ] || continue; case \"$p\" in [0-9]*) ;; *) echo \"skip $p\"; continue ;; esac; n=\"${r}-${d}-${p}\"; mv \"$p\" \"$n\"; echo \"$n\"; done; }; f" # Rename .patch files with repo-date prefix (skips already-renamed)

# ---- Branch & Checkout ----
co = checkout
cob = checkout -b # Create and switch to new branch
b = branch -vv # List branches with upstream/commit info
ba = branch -a -vv # List all local/remote branches
del = branch -D # Force delete branch
gone = "!git branch -vv | grep ': gone]' | awk '{print $1}' | xargs git branch -D" # Delete local branches whose remote was deleted
root = rev-parse --show-toplevel # Print repo root path
current = branch --show-current # Print current branch name

# ---- Pull / Push / Fetch ----
fap = fetch --all --prune # Fetch all and purge deleted remotes
fapr = "!git fap && git r" # Fetch all, prune, then rebase
p = pull
pu = pull
po = push origin
pof = push origin --force
pdel-branch = push origin --delete # Delete a remote branch: git pdel-branch <branch>
pdel-tag = push origin --delete --tag # Delete a remote tag: git pdel-tag <tag>
track = "!git branch --set-upstream-to=origin/$(git branch --show-current)" # Set upstream to origin

# ---- Rebase & Merge ----
rv = revert
rvc = revert --continue
mc = merge --continue
r = rebase --reapply-cherry-picks
rc = rebase --reapply-cherry-picks --continue
ri = rebase -i # Interactive rebase
ri-vscode = "!GIT_EDITOR=\"code --wait\" git ri"
rn = "!f() { git rebase -i HEAD~${1:-1}; }; f" # Interactive rebase last N commits
rn-code = "!f() { GIT_EDITOR=\"code --wait\" git rebase -i HEAD~${1:-1}; }; f"
ri-code = "!f() { GIT_EDITOR=\"code --wait\" git rebase -i ${1:-1}; }; f"

# ---- Log & Diff ----
logbaseline = log --decorate --all --abbrev-commit --date=short --graph
ls = "!git logbaseline --pretty=format:\"%C(yellow)%h %C(blue)%ad %C(green)%an %C(reset)%s\""
lls = "!git logbaseline --oneline --author-date-order"
l = "!git ls --stat" # Log with file stats
ll = "!git lls --stat" # Oneline log with file stats
d = diff --word-diff -w # Word-level diff ignoring whitespace
dh = diff --word-diff -w HEAD^ # Diff against previous commit
ds = diff --word-diff -w --staged # Diff staged changes
stats = shortlog -sn # Commit counts per author

# ---- Cherry-pick ----
cp = cherry-pick
cpc = cherry-pick --continue
cpn = cherry-pick -n # Cherry-pick without committing

# ---- Clone ----
clone0 = clone --depth 1 --single-branch  # Shallow clone
clone1 = clone --single-branch  # Full clone (single branch)
cl0 = "!f() { git clone0 \"$@\" >/dev/null 2>&1 & disown; echo \"[cl0] Shallow clone of ${1} started in background...\"; }; f"
cl1 = "!f() { git clone1 \"$@\" >/dev/null 2>&1 & disown; echo \"[cl1] Full clone of master for ${1} started in background...\"; }; f"

# ---- Search ----
search-logs = "!f() { git log -G \"$1\" -- .; }; f" # Search diff content of all commits: git search-logs <text>
search-reflog = rev-list --all -- # Find commits that touched a file: git search-reflog <file>
where-is = branch -r --contains # Find which remote branches contain a commit: git where-is <hash>

# ---- Cleanup ----
cleanfd = "!git merge --abort 2>/dev/null; git rebase --abort 2>/dev/null; git cherry-pick --abort 2>/dev/null; git am --abort 2>/dev/null; rm -rf .git/rebase-merge .git/rebase-apply .git/MERGE_HEAD .git/CHERRY_PICK_HEAD; git clean -f -d" # Abort all in-progress operations and remove untracked files

