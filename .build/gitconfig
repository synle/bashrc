[core]
autocrlf = input
editor = vim
excludesFile = ~/.gitignore_global
fsmonitor = true # Background daemon for status speed
untrackedCache = true # Caches untracked files
commitGraph = true # Speeds up log/history traversal
preloadIndex = true # Multi-threaded index scanning

[feature]
manyFiles = true # Grouped performance features

[index]
version = 4 # Path compression for large indexes

[checkout]
workers = 0 # Parallel file checkout (auto-detect CPU)

[fetch]
writeCommitGraph = true # Keeps the commit graph updated on fetch

[pull]
rebase = false

[push]
default = current

[diff]
tool = vimdiff
prompt = false

[merge]
tool = vimdiff
prompt = false

[color]
ui = true

[color "diff"]
meta = yellow
commit = green
frag = cyan
old = red
new = green
whitespace = red reverse

[color "diff-highlight"]
oldNormal = red bold
oldHighlight = red bold 52
newNormal = green bold
newHighlight = green bold 22

[diff-so-fancy]
markEmptyLines = false

[maintenance]
auto = true
strategy = incremental

[alias]
# General
s = "!bash -c 'git status -sb && git diff --stat' --"
stat = status -sb # Short status with branch info
a = add
aa = add -A # Add all (including untracked)
ap = add -p # Interactive patch mode
au = add -u # Add only tracked files

# Commit
c  = commit --allow-empty --no-verify
cm = commit --allow-empty --no-verify -m
amend  = commit --allow-empty --no-verify --amend
amendm = commit --allow-empty --no-verify --amend -m

# Patch and Smart patch download (default: HEAD~1, but accepts range)
patch = apply --reject --whitespace=fix
patch-apply = "!bash -c 'git patch' --"
patch-download = format-patch -1 --root
patch-download-raw = "!bash -c 'git patch-download --stdout' --"

# Branch & Checkout
co = checkout
cob = checkout -b # Create and switch to new branch
b = branch -vv # List branches with upstream/commit info
ba = branch -a -vv # List all local/remote branches
del = branch -D # Force delete branch

# Pull / Push / Fetch
fap = fetch --all --prune # Fetch all and purge deleted remotes
p = pull
pu = pull
po = push origin
pof = push origin --force
pdel-branch = push origin --delete # Delete a remote branch: branch-name
pdel-tag = push origin --delete --tag # Delete a remote tag: tag-name
track = "!bash -c 'git branch --set-upstream-to=origin/$(git branch --show-current)' --" # track

# Rebase & Merge
rv = revert
rvc = revert --continue
mc = merge --continue
r = rebase --reapply-cherry-picks
rc = rebase --reapply-cherry-picks --continue
ri = rebase -i # Interactive rebase
ri-vscode = "!bash -c 'GIT_EDITOR=\"code --wait\" git ri' --"

# Log & Diff
logbaseline = log --decorate --all --abbrev-commit --date=short --graph
ls = "!bash -c 'git logbaseline --pretty=format:\"%C(yellow)%h %C(blue)%ad %C(green)%an %C(reset)%s\"' --"
lls = "!bash -c 'git logbaseline --oneline --author-date-order' --"
l = "!bash -c 'git ls --stat' --"
ll = "!bash -c 'git lls --stat' --"
d = diff --word-diff -w # Word-level diff ignoring whitespace
dh = diff --word-diff -w HEAD^
ds = diff --word-diff -w --staged # Word-level diff ignoring whitespace
stats = shortlog -sn # Commit counts per author

# Maintenance & Advanced
cleanfd = "!bash -c 'git merge --abort 2>/dev/null; git rebase --abort 2>/dev/null; git cherry-pick --abort 2>/dev/null; git am --abort 2>/dev/null; rm -rf .git/rebase-merge .git/rebase-apply .git/MERGE_HEAD .git/CHERRY_PICK_HEAD; git clean -f -d' --" # Abort conflicts and remove untracked files/directories
cp = cherry-pick
cpc = cherry-pick --continue
cpn = cherry-pick -n # Cherry-pick without committing
clone0 = clone --depth 1 --single-branch  # Shallow Clone
clone1 = clone --single-branch  # Full Clone
cl0 = "!bash -c 'git clone0 \"$@\" >/dev/null 2>&1 & disown; echo \"[cl0] Shallow clone of ${1} started in background...\"' --"
cl1 = "!bash -c 'git clone1 \"$@\" >/dev/null 2>&1 & disown; echo \"[cl1] Full clone of master for ${1} started in background...\"' --"

# Search & Reflog
search-logs = "!bash -c 'git log -G \"$1\" -- .' --" # Usage: git search-logs <some_text_to_search>, Search the 'diff' content of all commits in the current directory for a specific string
