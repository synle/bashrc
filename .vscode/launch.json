{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Script (Current File)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/software/.debug-runner.js",
      "args": ["${file}"],
      "cwd": "${workspaceFolder}",
      "env": {
        "IS_LOCAL_MODE": "true",
        "BASH_PROFILE_CODE_REPO_RAW_URL": "https://github.com/synle/bashrc/blob/HEAD",
        "BASH_SYLE_PATH": "${env:HOME}/.bash_syle",
        "BASH_SYLE_COMMON_PATH": "${env:HOME}/.bash_syle_common",
        "is_os_mac": "1",
        "TZ": "UTC"
      },
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Vitest: Run All Tests",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/vitest",
      "args": ["run"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    },
    {
      "name": "Vitest: Debug Current Test File",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/vitest",
      "args": ["run", "${relativeFile}"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    }
  ]
}
