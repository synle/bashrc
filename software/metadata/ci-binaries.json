{
  "_doc": "Source of truth for CI binary verification (see .github/actions/ci-build/action.yml). Used by software/tools/build-include.js to populate the BEGIN/END ci-binary-checks block. Each list entry is either a string (binary name) or an object with `name` + optional `version_cmd`. Required = build fails if missing; warn = warning only.",
  "required": [
    "git",
    { "name": "git-filter-repo", "version_cmd": "git-filter-repo --version" },
    "curl",
    "make",
    "node",
    "npm",
    "fzf",
    "unzip",
    "yarn",
    "bun",
    "deno",
    "uv",
    { "name": "kubectl", "version_cmd": "kubectl version --client" },
    "gemini",
    "temporal",
    { "name": "http", "version_cmd": "http --version" },
    { "name": "ansible", "version_cmd": "ansible --version" },
    { "name": "btop", "version_cmd": "btop --version" },
    "starship",
    { "name": "ffmpeg", "version_cmd": "ffmpeg -version" }
  ],
  "warn": [
    { "name": "pwsh", "version_cmd": "pwsh --version" },
    { "name": "ollama", "version_cmd": "ollama --version" },
    { "name": "psql", "version_cmd": "psql --version" },
    { "name": "pgcli", "version_cmd": "pgcli --version" },
    { "name": "mycli", "version_cmd": "mycli --version" },
    { "name": "xh", "version_cmd": "xh --version" },
    { "name": "grpcurl", "version_cmd": "grpcurl --version" },
    { "name": "helm", "version_cmd": "helm version --short" },
    { "name": "k9s", "version_cmd": "k9s version --short" },
    { "name": "stern", "version_cmd": "stern --version" },
    { "name": "kubectx", "version_cmd": "kubectx --help" },
    { "name": "kubens", "version_cmd": "kubens --help" },
    { "name": "lazydocker", "version_cmd": "lazydocker --version" },
    { "name": "dive", "version_cmd": "dive --version" },
    { "name": "ctop", "version_cmd": "ctop -v" },
    { "name": "terraform", "version_cmd": "terraform version" },
    { "name": "tflint", "version_cmd": "tflint --version" },
    { "name": "procs", "version_cmd": "procs --version" },
    { "name": "btm", "version_cmd": "btm --version" },
    { "name": "gping", "version_cmd": "gping --version" },
    { "name": "aws", "version_cmd": "aws --version" },
    { "name": "az", "version_cmd": "az --version" },
    { "name": "gcloud", "version_cmd": "gcloud --version" }
  ]
}
