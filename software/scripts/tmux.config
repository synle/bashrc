## tmux set pane border title
## tmux set -g pane-border-status top

## status bar - minimal, show tab numbers
set -g status on
set -g status-style "bg=default,fg=white"
set -g window-status-format " #I:#W "
set -g window-status-current-format " #I:#W "
set -g window-status-current-style "bg=white,fg=black"
set -g status-left ""
set -g status-right ""

## scroll history
set -g history-limit 30000

##  Window options
set -g monitor-activity off

## mouse support
set -g mouse on

## clipboard - use system clipboard for copy/paste
set -g set-clipboard on
set -g allow-passthrough on
bind -T copy-mode MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "pbcopy"
bind -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "pbcopy"

## prefix+y to capture entire visible pane to system clipboard
bind y capture-pane -p \; run "tmux capture-pane -p | pbcopy" \; display "Pane copied to clipboard"

## pane borders - active pane has bright border
set -g pane-border-style "fg=colour240"
set -g pane-active-border-style "fg=white,bold"
set -g pane-border-lines heavy

## Autorename sanely.
setw -g automatic-rename on

## new window in current path
bind c new-window -c "#{pane_current_path}"

#""""""""""""""""""""""""""""""""""""""""""""""""
# Splitting (matches Windows Terminal: alt+d vertical, alt+' horizontal)
#""""""""""""""""""""""""""""""""""""""""""""""""
bind v split-window -c "#{pane_current_path}" -h
bind s split-window -c "#{pane_current_path}" -v
bind d split-window -h
bind -n M-d split-window -c "#{pane_current_path}" -h
bind -n M-"'" split-window -c "#{pane_current_path}" -v

#""""""""""""""""""""""""""""""""""""""""""""""""
# Navigate panes (matches Windows Terminal: alt+arrow)
#""""""""""""""""""""""""""""""""""""""""""""""""
bind -n M-Left select-pane -L
bind -n M-Right select-pane -R
bind -n M-Up select-pane -U
bind -n M-Down select-pane -D

#""""""""""""""""""""""""""""""""""""""""""""""""
# Resize panes (prefix + arrow)
#""""""""""""""""""""""""""""""""""""""""""""""""
bind Left resize-pane -L 2
bind Right resize-pane -R 2
bind Up resize-pane -U 2
bind Down resize-pane -D 2

#""""""""""""""""""""""""""""""""""""""""""""""""
# Close pane / window (matches Windows Terminal: alt+w close pane, alt+q close window)
#""""""""""""""""""""""""""""""""""""""""""""""""
bind -n M-w kill-pane
bind -n M-q confirm-before -p "kill window? (y/n)" kill-window

#""""""""""""""""""""""""""""""""""""""""""""""""
# Tabs / windows (matches Windows Terminal: alt+t new tab, alt+shift+[/] prev/next)
#""""""""""""""""""""""""""""""""""""""""""""""""
bind -n M-t new-window -c "#{pane_current_path}"
bind -n M-"}" next-window
bind -n M-"{" previous-window

#""""""""""""""""""""""""""""""""""""""""""""""""
# Switch to window by index (matches Windows Terminal: alt+1-9)
#""""""""""""""""""""""""""""""""""""""""""""""""
bind -n M-1 select-window -t 0
bind -n M-2 select-window -t 1
bind -n M-3 select-window -t 2
bind -n M-4 select-window -t 3
bind -n M-5 select-window -t 4
bind -n M-6 select-window -t 5
bind -n M-7 select-window -t 6
bind -n M-8 select-window -t 7
bind -n M-9 select-window -t 8

#""""""""""""""""""""""""""""""""""""""""""""""""
# Toggle fullscreen pane (matches Windows Terminal: alt+\ / f11)
#""""""""""""""""""""""""""""""""""""""""""""""""
bind -n M-\\ resize-pane -Z
