// OpenCode TUI keybinding overrides — applied on top of opencode's defaults
// (https://opencode.ai/docs/keybinds/). Only the chords listed here are
// touched; every other default is left intact via the deploy-time merge in
// software/scripts/advanced/llm/opencode/setup.js.
//
// EXPLICIT-MATCH POLICY
// ---------------------
// Every chord we want from Claude's convention is listed here EXPLICITLY,
// even if opencode's upstream default already happens to bind it. Rationale:
//   (a) An upstream default flip silently breaks our parity. Owning the
//       binding here means a re-run of opencode/setup.js always converges
//       to the Claude-aligned chord even if opencode changes defaults.
//   (b) The file is auditable in isolation — no need to consult opencode's
//       schema docs to know which chords we "have".
//   (c) The cross-tool comparison table in docs/editor-keybindings.md only
//       credits chords that are explicitly listed in our key files; no
//       "happens to align with upstream default" entries.
//
// Opencode uses "super" as its cross-platform term for the primary OS
// modifier (Cmd on macOS, Super/Windows key on Linux). All chords use
// "super" directly — no OS-specific substitution needed.
//
// Direct mirror of software/scripts/advanced/llm/claude/claude-keys.common.jsonc:
//
//   Claude action               OpenCode command            Claude chord(s)
//   ───────────────────────────  ──────────────────────────  ────────────────────────
//   chat:newline                input_newline               shift+enter, ctrl+enter
//   chat:undo                   input_undo                  OS_KEY+z
//   chat:clearInput             input_clear                 OS_KEY+l
//   chat:externalEditor         editor_open                 ctrl+x
//   chat:imagePaste             input_paste                 ctrl+v
//   (readline HOME, ctrl+a null) input_line_home            ctrl+a, home
//   (readline END, ctrl+e null)  input_line_end             ctrl+e, end
//
// Claude chords with NO opencode equivalent (gaps documented in
// docs/editor-keybindings.md):
//   app:toggleTodos (ctrl+t) — opencode has no todos panel; default ctrl+t
//                              = variant_cycle, kept intact (NOT overridden
//                              below).
//
// Opencode-specific additions (no Claude equivalent — kept for cross-app
// muscle memory):
//   sidebar_toggle    ctrl+\,tab  — matches Sublime/VS Code/Zed sidebar
//                                   toggle; tab is the alternate for quick
//                                   panel access.
//   input_buffer_home ctrl+home,super+home — start of multi-line buffer.
//   input_buffer_end  ctrl+end,super+end   — end of multi-line buffer.
//   yank_last_code    ctrl+y               — yank last code block from
//                                            assistant response.
//
// Leader move:
//   The default leader is ctrl+x — which collides with Claude's editor-open
//   chord (chat:externalEditor → ctrl+x → opens vim). We move the leader to
//   ctrl+o (free in both opencode and bash readline; no tmux / XON-XOFF /
//   terminal-level conflict) so ctrl+x can be repurposed for editor_open.
//   All ~30 <leader>X chords keep working — they're just typed as
//   ctrl+o <key> now instead of ctrl+x <key>.
//
// Sidebar-hidden-by-default is NOT supported by opencode v1.14.33:
//   - The TUI schema (https://opencode.ai/tui.json) has no field for it.
//   - The opencode SQLite db has no settings table for view state.
//   - The command-palette "Hide sidebar" command (ctrl+p) is a runtime
//     toggle only, not persisted between launches.
//   - The only knob is the toggle keybind (now ctrl+\ or tab).
//   Documented as a permanent gap in docs/editor-keybindings.md.
//
// TODO(future): opencode's docs flag the top-level `keybinds` key in
// opencode.json as deprecated (auto-migrated). The canonical location is
// now ~/.config/opencode/tui.json. Migrate the writer in setup.js when
// upstream removes the auto-migration shim.
{
  "keybinds": {
    // Move leader off ctrl+x so we can bind ctrl+x directly to editor_open.
    // See header comment for rationale. Every <leader>X chord (~30 of them:
    // <leader>e editor, <leader>n new session, <leader>t themes, <leader>m
    // models, etc.) continues to work, just with ctrl+o as the prefix.
    // session_rename: moved to f6 to free f2 for sidebar_toggle.
    "session_rename": "f6",
    "leader": "ctrl+o",
    // Open $EDITOR (typically vim) to compose input. Mirrors Claude's
    // ctrl+x → chat:externalEditor.
    "editor_open": "ctrl+x",
    // Newline in input. Claude binds shift+enter / ctrl+enter. We list
    // every chord explicitly (no reliance on opencode default) plus
    // alt+return / ctrl+j which opencode upstream historically shipped.
    "input_newline": "shift+return,ctrl+return,alt+return,ctrl+j",
    // Beginning of current input line. We bind both ctrl+a and the physical
    // HOME key to input_line_home so the user-visible behavior matches across
    // Sublime, VS Code, Zed, and bash readline. For multi-line input, this
    // jumps to the start of the current line; ctrl+home/super+home jump to
    // the start of the whole buffer (see input_buffer_home below).
    "input_line_home": "ctrl+a,home",
    // End of current input line. Mirror of input_line_home — binds ctrl+e
    // and the physical END key.
    "input_line_end": "ctrl+e,end",
    // Beginning of the entire input buffer (only different from
    // input_line_home for multi-line input). Bound to ctrl+home and super+home
    // since bare HOME now belongs to input_line_home above.
    "input_buffer_home": "ctrl+home,super+home",
    // End of the entire input buffer. Bound to ctrl+end and super+end since
    // bare END now belongs to input_line_end above.
    "input_buffer_end": "ctrl+end,super+end",
    // Clear current input. Claude binds super+l (cmd+l mac, super+l linux).
    // We also layer ctrl+l (bash readline convention).
    "input_clear": "super+l,ctrl+l",
    // Undo last typed input. Claude binds super+z (cmd+z mac, super+z linux).
    // We layer ctrl+- (opencode legacy chord) and keep super+z as an
    // alternate.
    "input_undo": "super+z,ctrl+-,super+z",
    // Paste into the input field. Claude binds ctrl+v → chat:imagePaste;
    // opencode's input_paste is text-paste (no image pipeline today).
    // Listed explicitly so a future upstream default flip can't drop it.
    "input_paste": "ctrl+v",
    // Copy messages from the assistant's response. ctrl+y matches the
    // bash-readline yank convention for muscle-memory carryover.
    "messages_copy": "ctrl+y",
    // Command list / palette. ctrl+p is the opencode upstream default
    // (file-finder); super+l is the cross-app convention matching
    // Sublime / VS Code / Zed command palette.
    "command_list": "ctrl+p,super+p",
    // Toggle sidebar (sessions / files / MCP pane). Default is "<leader>b";
    // we add ctrl+\ as the primary chord (matches cross-app sidebar-toggle
    // convention used by Sublime / VS Code / Zed) and tab as an alternate for
    // quick panel access. The "\\" in the JSON source represents a literal
    // backslash; after JSON parse the chord is "ctrl+\" for bare
    // ctrl+backslash.
    "sidebar_toggle": "ctrl+\\,tab",
  },
}
