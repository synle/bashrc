// Zed user keymap. OS_KEY = `cmd` on macOS, `alt` on Windows/Linux.
// Zed keymap separator is `-` (per CLAUDE.md). Resolved by zed.js.
// zed.js also auto-appends a `context: "Terminal"` entry mirroring every
// OS-modifier binding from this no-context entry, so OS_KEY+X chords fire
// from terminal focus too ‚Äî the terminal pane otherwise consumes alt-/cmd-
// chords as Meta and forwards them to the shell. Add new bindings here
// (no-context block) and they get the terminal-mirror treatment for free.
// Bindings are mirrored from vs-code-keys.common.jsonc + vs-code-keys.windows.jsonc
// (per-action equivalents in the Zed `editor::*` / `workspace::*` / `pane::*` /
// `zed::*` action namespaces) so muscle memory stays consistent across editors.
[
  {
    "bindings": {
      // NOTE on `\` vs `|` in this keymap:
      // Zed normalises a `shift+\` keypress to the resulting glyph "|" before
      // dispatching, so any user binding written as `shift-OS_KEY-\` is never
      // matched and the corresponding default (e.g.
      // `cmd-|` -> `editor::MoveToEnclosingBracket`) wins instead. To override
      // shifted-backslash chords, write them with `|` directly.
      // The PHYSICAL chord is unchanged ‚Äî on a US keyboard `cmd+shift+\` and
      // `cmd+|` are the same keypress.

      // ---- Sidebar / panels ----
      // toggle the left dock (project panel / file tree) ‚Äî matches Sublime's
      // `toggle_side_bar` and VS Code's `workbench.action.toggleSidebarVisibility`
      "OS_KEY-\\": "workspace::ToggleLeftDock",
      // toggle the right dock ‚Äî matches VS Code's `toggleAuxiliaryBar`
      "OS_KEY-|": "workspace::ToggleRightDock",
      // toggle soft wrap ‚Äî matches VS Code/Sublime's `ctrl+shift+OS_KEY+\`
      "ctrl-OS_KEY-|": "editor::ToggleSoftWrap",
      // toggle the terminal panel ‚Äî same chord across mac/linux/windows.
      // `ctrl-`` is Zed's default everywhere; lock it in explicitly so a
      // future default change can't silently break it. Mirrors VS Code's
      // `ctrl+`` -> workbench.action.terminal.toggleTerminal.
      "ctrl-`": "terminal_panel::Toggle",
      // F5 ‚Äî revert/reload the active file from disk. Matches VS Code's
      // `workbench.action.files.revert` and Sublime's chained `revert` +
      // `refresh_folder_list`. Zed's project panel auto-watches the
      // filesystem (no manual refresh action exists in `project_panel::*`),
      // so reverting the buffer is enough ‚Äî the tree updates on its own.
      "f5": "workspace::ReloadActiveItem",

      // ---- Tabs / panes / windows ----
      // new file tab ‚Äî matches VS Code `workbench.action.files.newUntitledFile` / Sublime `new_file`
      "OS_KEY-n": "workspace::NewFile",
      // new window ‚Äî matches VS Code `workbench.action.newWindow`
      "OS_KEY-shift-n": "workspace::NewWindow",
      // tab navigation ‚Äî matches VS Code nextEditor/previousEditor + Sublime next_view/prev_view
      "OS_KEY-shift-]": "pane::ActivateNextItem",
      "OS_KEY-shift-[": "pane::ActivatePrevItem",
      // close active tab ‚Äî matches VS Code `workbench.action.closeActiveEditor`
      "OS_KEY-w": "pane::CloseActiveItem",
      // open file picker (quick open) ‚Äî matches VS Code `workbench.action.quickOpen`
      "OS_KEY-p": "file_finder::Toggle",
      // command palette ‚Äî matches VS Code `workbench.action.showCommands`
      "OS_KEY-shift-p": "command_palette::Toggle",

      // ---- File operations ----
      // save / save all ‚Äî matches VS Code `workbench.action.files.save{,All}`
      "OS_KEY-s": "workspace::Save",
      "OS_KEY-shift-s": "workspace::SaveAll",

      // ---- Editing ----
      // select all ‚Äî matches VS Code `editor.action.selectAll`
      "OS_KEY-a": "editor::SelectAll",
      // copy / paste / cut. Auto-mirrored to Terminal context by zed.js, but the
      // explicit Terminal-context block below overrides copy/paste with terminal::*
      // because editor::* actions are no-ops in the terminal pane.
      "OS_KEY-c": "editor::Copy",
      "OS_KEY-v": "editor::Paste",
      "OS_KEY-x": "editor::Cut",
      // undo / redo ‚Äî matches VS Code alt+z, alt+shift+z, alt+y
      "OS_KEY-z": "editor::Undo",
      "OS_KEY-shift-z": "editor::Redo",
      "OS_KEY-y": "editor::Redo",
      // toggle line comment ‚Äî matches VS Code `editor.action.commentLine`
      "OS_KEY-/": "editor::ToggleComments",
      // indent / outdent ‚Äî matches VS Code `editor.action.{indent,outdent}Lines`
      "OS_KEY-]": "editor::Indent",
      "OS_KEY-[": "editor::Outdent",
      // add selection to next find match ‚Äî matches VS Code `editor.action.addSelectionToNextFindMatch`
      "OS_KEY-d": "editor::SelectNext",

      // ---- Find / search ----
      // find in buffer ‚Äî matches VS Code `actions.find`
      "OS_KEY-f": "buffer_search::Deploy",
      // find next / previous (after deploy) ‚Äî matches VS Code's move-selection-to-next/prev-find-match
      "OS_KEY-g": "search::SelectNextMatch",
      "OS_KEY-shift-g": "search::SelectPrevMatch",
      // replace in buffer ‚Äî matches VS Code `editor.action.startFindReplaceAction`
      "OS_KEY-h": "buffer_search::DeployReplace",
      // find / replace across project ‚Äî matches VS Code findInFiles / replaceInFiles
      "OS_KEY-shift-f": "workspace::NewSearch",
      "OS_KEY-shift-h": "workspace::NewSearch",

      // ---- Navigation ----
      // go to line ‚Äî matches VS Code `workbench.action.gotoLine`
      "OS_KEY-;": "go_to_line::Toggle",
      // go to symbol in file ‚Äî matches VS Code `workbench.action.gotoSymbol`
      "OS_KEY-r": "outline::Toggle",
      // go to symbol across project ‚Äî matches VS Code `workbench.action.showAllSymbols`
      "OS_KEY-shift-'": "project_symbols::Toggle",
      // go to definition ‚Äî matches VS Code `editor.action.revealDefinition`
      "OS_KEY-enter": "editor::GoToDefinition",
      // find references ‚Äî matches VS Code `editor.action.goToReferences`
      "shift-enter": "editor::FindAllReferences",

      // ---- Folding ----
      // fold / unfold ‚Äî matches VS Code `editor.{fold,unfold}`
      "OS_KEY-,": "editor::Fold",
      "OS_KEY-.": "editor::UnfoldLines",

      // ---- Zoom ----
      // buffer (editor) font zoom ‚Äî matches VS Code `editor.action.fontZoom{In,Out,Reset}`
      "OS_KEY-=": "zed::IncreaseBufferFontSize",
      "OS_KEY--": "zed::DecreaseBufferFontSize",
      "OS_KEY-0": "zed::ResetBufferFontSize",
      // UI font zoom ‚Äî matches VS Code `workbench.action.zoom{In,Out}`
      "OS_KEY-shift-=": "zed::IncreaseUiFontSize",
      "OS_KEY-shift--": "zed::DecreaseUiFontSize",

      // ---- Rename (F2 across all editors) ----
      "f2": "editor::Rename",
    },
  },
  {
    // Terminal-focus overrides: copy/paste must use terminal::* actions because
    // editor::Copy / editor::Paste are no-ops in the terminal pane. The auto-mirror
    // in zed.js detects an explicit Terminal-context binding for a chord and skips
    // mirroring the editor::* version on top of it.
    "context": "Terminal",
    "bindings": {
      "OS_KEY-c": "terminal::Copy",
      "OS_KEY-v": "terminal::Paste",
    },
  },
]
