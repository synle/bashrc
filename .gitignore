# Release-asset fallback cache lives in the binary-cache release on synle/bashrc,
# not in the repo. Block accidental local re-introduction.
assets/binaries/

# Per-OS precompiled profile snapshots are generated by each CI build job,
# uploaded as `profile-build-*` artifacts (copied into dist/ by publish for
# the webapp to fetch same-origin), and mirrored to the binary-cache release
# as `bashrc-profile__profile_bashrc_<os>.sh`. Never committed back.
.build/profile_bashrc_*.sh


